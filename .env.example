# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas (replace with your Atlas URI)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ecommerce

# Frontend URL (your deployed frontend URL)
FRONTEND_URL=https://your-frontend.onrender.com

# Auth
JWT_SECRET=change_this_to_a_long_random_string_in_production
SELLER_SECRET_KEY=UDAY@STEELS#2024

# OTP
OTP_EXPIRY_MINUTES=10

# Gmail (for OTP emails and order notifications)
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASS=your_16_char_app_password

# Razorpay (get from razorpay.com dashboard)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# PhonePe (optional)
PHONEPE_MERCHANT_ID=UDAYSTEELS
PHONEPE_SALT_KEY=udaysteels_salt_2024
PHONEPE_SALT_INDEX=1
